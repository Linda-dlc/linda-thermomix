---
interface Props {
  image: string;
  title: string;
  description?: string;
}

const { image, title, description } = Astro.props;
---

<article class="group bg-white rounded-sm overflow-hidden shadow-sm hover:shadow-md transition-shadow">
  <div class="overflow-hidden">
    <img
      src={image}
      alt={title}
      class="w-full h-auto group-hover:scale-[1.03] transition-transform duration-500"
      loading="lazy"
    />
  </div>
  {(title || description) && (
    <div class="p-6">
      {title && <h3 class="text-lg font-bold mb-2">{title}</h3>}
      {description && <p class="text-[var(--color-warm-gray)] text-sm">{description}</p>}
    </div>
  )}
</article>
