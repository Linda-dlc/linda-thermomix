---
interface Props {
  image: string;
  imageAlt: string;
  headline: string;
  subline?: string;
  cta1?: { label: string; href: string };
  cta2?: { label: string; href: string };
}

const { image, imageAlt, headline, subline, cta1, cta2 } = Astro.props;
---

<section class="bg-[var(--color-cream)]">
  <div class="max-w-6xl mx-auto px-6 py-16 md:py-24 grid md:grid-cols-2 gap-12 items-center">
    <!-- Foto links -->
    <div class="order-2 md:order-1 animate-fade-in">
      <img
        src="/assets/fotos/linda-hero.jpg"
        alt="Linda De La Cruz Perea"
        width="1366"
        height="2048"
        style="width:100%; height:auto; display:block; border-radius:4px; box-shadow:0 10px 15px -3px rgba(0,0,0,0.1);"
        loading="eager"
      />
    </div>

    <!-- Text rechts -->
    <div class="order-1 md:order-2">
      <h1 class="mb-6 animate-fade-in-up">
        {headline}
      </h1>
      {subline && (
        <p class="text-lg md:text-xl text-[var(--color-warm-gray)] mb-10 animate-fade-in-up delay-1 font-light leading-relaxed">
          {subline}
        </p>
      )}
      <div class="flex flex-col sm:flex-row gap-4 animate-fade-in-up delay-2">
        {cta1 && (
          <a
            href={cta1.href}
            style="color: #FAF7F2; background-color: #C4775A;"
            class="inline-block px-8 py-4 font-semibold rounded-sm hover:opacity-90 hover:scale-[1.02] transition-all text-center"
          >
            {cta1.label}
          </a>
        )}
        {cta2 && (
          <a
            href={cta2.href}
            style="color: #C4775A; border: 2px solid #C4775A;"
            class="inline-block px-8 py-4 font-semibold rounded-sm hover:bg-[var(--color-terracotta)] hover:text-[var(--color-cream)] transition-all text-center"
          >
            {cta2.label}
          </a>
        )}
      </div>
    </div>
  </div>
</section>
