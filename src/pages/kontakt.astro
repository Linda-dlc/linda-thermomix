---
import BaseLayout from '../layouts/BaseLayout.astro';
import KontaktFormular from '../components/KontaktFormular.astro';
import LocalBusinessSchema from '../components/LocalBusinessSchema.astro';
---

<BaseLayout
  title="Kontakt & Terminbuchung · Thermomix Mainz"
  description="Termin für eine kostenlose Thermomix-Vorführung in Mainz & Umgebung vereinbaren. Per Telefon, WhatsApp oder Kontaktformular."
>
  <LocalBusinessSchema />

  <!-- Header -->
  <section class="py-20 px-6 bg-[var(--color-peach)]/30">
    <div class="max-w-4xl mx-auto text-center">
      <h1 class="mb-6 animate-fade-in-up">Lass uns einen Termin finden</h1>
      <p class="text-lg text-[var(--color-warm-gray)] animate-fade-in-up delay-1">
        Ruf mich an, schreib mir oder nutze das Formular – ich melde mich schnell zurück!
      </p>
    </div>
  </section>

  <!-- Kontakt-Info + Formular -->
  <section class="py-16 px-6">
    <div class="max-w-6xl mx-auto grid md:grid-cols-5 gap-12">
      <!-- Kontakt-Info -->
      <div class="md:col-span-2 reveal">
        <h2 class="mb-6">Direkt erreichen</h2>

        <div class="space-y-6">
          <!-- Telefon -->
          <div>
            <p class="text-sm uppercase tracking-wider text-[var(--color-warm-gray)] font-semibold mb-1">Telefon</p>
            <a href="tel:+4917631276883" class="text-2xl font-bold text-[var(--color-terracotta)] hover:text-[var(--color-terracotta-dark)]">
              0176 31276883
            </a>
          </div>

          <!-- E-Mail -->
          <div>
            <p class="text-sm uppercase tracking-wider text-[var(--color-warm-gray)] font-semibold mb-1">E-Mail</p>
            <a href="mailto:linda.de-la-cruz-perea@thermomix-kundenberatung.de" class="text-[var(--color-terracotta)] hover:text-[var(--color-terracotta-dark)] break-all">
              linda.de-la-cruz-perea@thermomix-kundenberatung.de
            </a>
          </div>

          <!-- Region -->
          <div>
            <p class="text-sm uppercase tracking-wider text-[var(--color-warm-gray)] font-semibold mb-1">Region</p>
            <p>Nackenheim, Mainz & Umgebung</p>
            <p class="text-sm text-[var(--color-warm-gray)]">Ingelheim · Bingen · Nieder-Olm · Rheinhessen</p>
          </div>
        </div>

        <!-- Hinweis -->
        <div class="mt-8 p-6 bg-[var(--color-peach)]/40 rounded-sm">
          <p class="text-sm text-[var(--color-warm-gray)] leading-relaxed">
            Am schnellsten erreichst du mich telefonisch oder per WhatsApp.
            Ich antworte meistens innerhalb weniger Stunden!
          </p>
        </div>
      </div>

      <!-- Formular -->
      <div class="md:col-span-3 reveal delay-1">
        <h2 class="mb-6">Nachricht schreiben</h2>
        <KontaktFormular formName="kontakt" />
      </div>
    </div>
  </section>
</BaseLayout>
