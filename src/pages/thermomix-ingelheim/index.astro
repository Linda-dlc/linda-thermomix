---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTAButton from '../../components/CTAButton.astro';
import KontaktFormular from '../../components/KontaktFormular.astro';
---

<BaseLayout
  title="Thermomix Vorführung Ingelheim · Deine Beraterin"
  description="Deine Thermomix-Beraterin für Ingelheim am Rhein. Kostenlose Vorführung & Beratung bei dir zuhause. Jetzt Termin buchen!"
>
  <section class="py-20 px-6 bg-[var(--color-peach)]/30">
    <div class="max-w-4xl mx-auto text-center">
      <h1 class="mb-6 animate-fade-in-up">Deine Thermomix-Beraterin in Ingelheim am Rhein</h1>
      <p class="text-lg text-[var(--color-warm-gray)] animate-fade-in-up delay-1">
        Persönliche Beratung und kostenlose Vorführung – ich komme zu dir nach Ingelheim.
      </p>
    </div>
  </section>

  <section class="py-16 px-6">
    <div class="max-w-3xl mx-auto reveal">
      <h2 class="mb-6">Thermomix TM7 in Ingelheim erleben</h2>
      <p class="text-[var(--color-warm-gray)] text-lg leading-relaxed mb-6">
        Du wohnst in Ingelheim am Rhein und interessierst dich für den Thermomix? Perfekt!
        Ich bin Linda, deine Thermomix-Repräsentantin aus dem benachbarten Nackenheim, und
        komme gerne zu dir nach Ingelheim für eine kostenlose Vorführung.
      </p>
      <p class="text-[var(--color-warm-gray)] text-lg leading-relaxed mb-6">
        Beim Erlebniskochen in Ingelheim zeige ich dir und deinen Freundinnen, was der
        Thermomix TM7 alles kann. Wir kochen zusammen ein leckeres Menü – vom Smoothie bis
        zum Hauptgericht. Alles in deiner eigenen Küche, entspannt und unverbindlich.
      </p>
      <p class="text-[var(--color-warm-gray)] text-lg leading-relaxed mb-8">
        Der Thermomix TM7 ist ab 1.549 € erhältlich. Ich berate dich gerne zu allen
        Finanzierungsmöglichkeiten und aktuellen Aktionen. In Ingelheim und der gesamten
        Region Mainz-Bingen bin ich für dich da!
      </p>
      <div class="flex flex-col sm:flex-row gap-4">
        <CTAButton href="tel:+4917631276883" label="0176 31276883 anrufen" />
        <CTAButton href="/erlebniskochen/" label="Erlebniskochen buchen" variant="outline" />
      </div>
    </div>
  </section>

  <section class="py-16 px-6 bg-white">
    <div class="max-w-3xl mx-auto text-center reveal">
      <h2 class="mb-6">Auch in der Nähe</h2>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/thermomix-nackenheim/" class="px-6 py-3 bg-[var(--color-cream)] rounded-sm shadow-sm hover:shadow-md transition-shadow font-semibold">Nackenheim</a>
        <a href="/kontakt/" class="px-6 py-3 bg-[var(--color-cream)] rounded-sm shadow-sm hover:shadow-md transition-shadow font-semibold">Mainz</a>
        <a href="/thermomix-bingen/" class="px-6 py-3 bg-[var(--color-cream)] rounded-sm shadow-sm hover:shadow-md transition-shadow font-semibold">Bingen</a>
        <a href="/thermomix-rheinhessen/" class="px-6 py-3 bg-[var(--color-cream)] rounded-sm shadow-sm hover:shadow-md transition-shadow font-semibold">Rheinhessen</a>
      </div>
    </div>
  </section>

  <section class="py-16 px-6">
    <div class="max-w-2xl mx-auto reveal">
      <h2 class="mb-6">Nachricht schreiben</h2>
      <KontaktFormular formName="kontakt-ingelheim" />
    </div>
  </section>
</BaseLayout>
