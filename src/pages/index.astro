---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import AngebotCard from '../components/AngebotCard.astro';
import CTAButton from '../components/CTAButton.astro';
import LocalBusinessSchema from '../components/LocalBusinessSchema.astro';
import fs from 'node:fs';

// Read CMS content for dynamic images
let angebot1 = '/assets/angebote/angebot-tm7-paket.jpg';
let angebot2 = '/assets/angebote/angebot-geschenke.jpg';
let angebot3 = '/assets/angebote/angebot-0prozent.jpg';

try {
  const raw = fs.readFileSync('src/content/angebote/angebote.md', 'utf-8');
  const match1 = raw.match(/angebot1:\s*(.+)/);
  const match2 = raw.match(/angebot2:\s*(.+)/);
  const match3 = raw.match(/angebot3:\s*(.+)/);
  if (match1) angebot1 = match1[1].trim();
  if (match2) angebot2 = match2[1].trim();
  if (match3) angebot3 = match3[1].trim();
} catch {}
---

<BaseLayout
  title="Thermomix Beratung Mainz · Linda De La Cruz Perea"
  description="Thermomix TM7 Beratung in Mainz & Umgebung. Kostenlose Vorführung bei dir zuhause. Jetzt Termin mit Linda vereinbaren! ☎ 0176 31276883"
>
  <LocalBusinessSchema />

  <!-- Hero -->
  <Hero
    image="/assets/fotos/linda-profil-1.jpg"
    imageAlt="Linda De La Cruz Perea – Thermomix Beraterin in Mainz"
    headline="Deine Thermomix-Expertin in Mainz & Umgebung"
    subline="Erlebe den Thermomix TM7 live bei dir zuhause – kostenlos und unverbindlich. Ich komme zu dir!"
    cta1={{ label: 'Erlebniskochen buchen', href: '/erlebniskochen/' }}
    cta2={{ label: 'Aktuelle Angebote', href: '/angebote/' }}
  />

  <!-- USPs / Vertrauen -->
  <section class="py-20 px-6">
    <div class="max-w-6xl mx-auto grid md:grid-cols-3 gap-12 text-center">
      <div class="reveal">
        <div class="w-16 h-16 mx-auto mb-6 rounded-full bg-[var(--color-peach)] flex items-center justify-center">
          <svg class="w-8 h-8 text-[var(--color-terracotta)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
          </svg>
        </div>
        <h3 class="mb-3">Persönlich vor Ort</h3>
        <p class="text-[var(--color-warm-gray)]">Ich komme zu dir nach Hause – keine Anfahrt, kein Stress. Einfach kochen und genießen.</p>
      </div>
      <div class="reveal delay-1">
        <div class="w-16 h-16 mx-auto mb-6 rounded-full bg-[var(--color-peach)] flex items-center justify-center">
          <svg class="w-8 h-8 text-[var(--color-terracotta)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" />
          </svg>
        </div>
        <h3 class="mb-3">Mainz & Nackenheim</h3>
        <p class="text-[var(--color-warm-gray)]">Nackenheim, Mainz, Ingelheim, Bingen und ganz Rheinhessen – ich bin für dich da.</p>
      </div>
      <div class="reveal delay-2">
        <div class="w-16 h-16 mx-auto mb-6 rounded-full bg-[var(--color-peach)] flex items-center justify-center">
          <svg class="w-8 h-8 text-[var(--color-terracotta)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z" />
          </svg>
        </div>
        <h3 class="mb-3">Erfahrene Repräsentantin</h3>
        <p class="text-[var(--color-warm-gray)]">Ehrliche Beratung, kein Verkaufsdruck. Ich zeige dir, was der Thermomix wirklich kann.</p>
      </div>
    </div>
  </section>

  <!-- Aktuelle Angebote -->
  <section class="py-20 px-6 bg-white">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-center mb-4 reveal">Aktuelle Angebote</h2>
      <p class="text-center text-[var(--color-warm-gray)] mb-12 max-w-2xl mx-auto reveal delay-1">
        Entdecke die neuesten Thermomix TM7 Angebote und Aktionen – jeden Monat neu.
      </p>
      <div class="grid md:grid-cols-3 gap-8 reveal delay-2">
        <AngebotCard
          image={angebot1}
          title="TM7 Paket"
          description="Ab 1.549 € – der Thermomix TM7 mit allem was du brauchst."
        />
        <AngebotCard
          image={angebot2}
          title="Entspannt-kochen-Paket"
          description="1.649 € inkl. 2. Mixtopf – bis 29.03.2026."
        />
        <AngebotCard
          image={angebot3}
          title="0%-Finanzierung"
          description="24 Raten à 67,50 € – bis 29.03.2026."
        />
      </div>
      <div class="text-center mt-10">
        <CTAButton href="/angebote/" label="Alle Angebote ansehen" variant="outline" />
      </div>
    </div>
  </section>

  <!-- Was ist Erlebniskochen? -->
  <section class="py-20 px-6">
    <div class="max-w-6xl mx-auto grid md:grid-cols-5 gap-12 items-center">
      <div class="md:col-span-3 reveal">
        <h2 class="mb-6">Was ist ein Erlebniskochen?</h2>
        <p class="text-[var(--color-warm-gray)] text-lg mb-6 leading-relaxed">
          Lade 3 Freunde ein, ich bringe den Thermomix mit. Wir kochen gemeinsam ein leckeres Menü –
          ihr probiert alles und erlebt den Thermomix hautnah. Kostenlos, unverbindlich und
          mit jeder Menge Spaß!
        </p>
        <p class="text-[var(--color-warm-gray)] mb-8">
          Als Gastgeberin bekommst du ein tolles Geschenk aus dem Katalog – als Dankeschön.
        </p>
        <CTAButton href="/erlebniskochen/" label="Erlebniskochen buchen" />
      </div>
      <div class="md:col-span-2 reveal delay-2">
        <img
          src="/assets/erlebniskochen.jpg"
          alt="Erlebniskochen mit Thermomix"
          class="w-full rounded-lg shadow-lg object-cover"
          loading="eager"
        />
      </div>
    </div>
  </section>

  <!-- Über Linda Teaser -->
  <section class="py-20 px-6 bg-[var(--color-peach)]/40">
    <div class="max-w-6xl mx-auto text-center reveal">
      <h2 class="mb-6">Hallo, ich bin Linda!</h2>
      <p class="text-lg text-[var(--color-warm-gray)] max-w-2xl mx-auto mb-8 leading-relaxed">
        Als Thermomix-Repräsentantin für Nackenheim, Mainz und Umgebung liebe ich es,
        Menschen beim Kochen zum Staunen zu bringen. Ehrlich, persönlich und immer mit einem Lächeln.
      </p>
      <CTAButton href="/ueber-linda/" label="Mehr über mich" variant="outline" />
    </div>
  </section>

  <!-- Lokale Präsenz -->
  <section class="py-20 px-6">
    <div class="max-w-6xl mx-auto text-center reveal">
      <h2 class="mb-8">Deine Region – mein Zuhause</h2>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/thermomix-nackenheim/" class="px-6 py-3 bg-white rounded-sm shadow-sm hover:shadow-md transition-shadow text-[var(--color-espresso)] font-semibold">Nackenheim</a>
        <a href="/kontakt/" class="px-6 py-3 bg-white rounded-sm shadow-sm hover:shadow-md transition-shadow text-[var(--color-espresso)] font-semibold">Mainz</a>
        <a href="/thermomix-ingelheim/" class="px-6 py-3 bg-white rounded-sm shadow-sm hover:shadow-md transition-shadow text-[var(--color-espresso)] font-semibold">Ingelheim</a>
        <a href="/thermomix-bingen/" class="px-6 py-3 bg-white rounded-sm shadow-sm hover:shadow-md transition-shadow text-[var(--color-espresso)] font-semibold">Bingen</a>
        <a href="/thermomix-rheinhessen/" class="px-6 py-3 bg-white rounded-sm shadow-sm hover:shadow-md transition-shadow text-[var(--color-espresso)] font-semibold">Rheinhessen</a>
      </div>
    </div>
  </section>

  <!-- Kontakt CTA -->
  <section class="py-20 px-6 bg-[var(--color-terracotta)]">
    <div class="max-w-3xl mx-auto text-center text-[var(--color-cream)]">
      <h2 class="text-[var(--color-cream)] mb-6">Lass uns kochen!</h2>
      <p class="text-lg mb-8 opacity-90">
        Ruf mich an oder schreib mir – ich freu mich auf dich!
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="tel:+4917631276883"
          class="inline-block px-8 py-4 bg-[var(--color-cream)] text-[var(--color-terracotta)] font-semibold rounded-sm hover:scale-[1.02] transition-all text-center"
        >
          0176 31276883
        </a>
        <a
          href="/kontakt/"
          class="inline-block px-8 py-4 border-2 border-[var(--color-cream)] text-[var(--color-cream)] font-semibold rounded-sm hover:bg-[var(--color-cream)] hover:text-[var(--color-terracotta)] transition-all text-center"
        >
          Kontaktformular
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
